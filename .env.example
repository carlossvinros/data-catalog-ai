# === Kaggle API ===
KAGGLE_USERNAME=kaggle_username_here
KAGGLE_API_TOKEN=kaggle_api_token_here

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=data_catalog
POSTGRES_USER=catalog_user
POSTGRES_PASSWORD=change_me_in_production

# === AI Agents ===
OPENAI_API_KEY=your_openai_api_key
# Alternatively, use a local model:
# OLLAMA_BASE_URL=http://localhost:11434

# === Application ===
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# === Anonymization ===
# H3 resolution: 7 = ~150m radius, 8 = ~50m, 9 = ~17m
H3_RESOLUTION=7
MAC_HASH_SALT=generate_a_random_salt_here
