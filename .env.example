# === Kaggle API ===
# Obtenha em: https://www.kaggle.com/settings > API > Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# === LLM — Groq (recomendado: gratuito e rápido) ===
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# === LLM — Google Gemini (alternativa) ===
# Obtenha em: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key

# === PostgreSQL (deve coincidir com o docker-compose.yml) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=data_catalog
POSTGRES_USER=catalog_user
POSTGRES_PASSWORD=change_me_in_production

# === Aplicação ===
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# === Anonimização ===
# H3 resolution: 7 = ~150m, 8 = ~50m, 9 = ~17m
H3_RESOLUTION=7
# Gere um salt único: python -c "import secrets; print(secrets.token_hex(32))"
MAC_HASH_SALT=generate_a_random_salt_here
